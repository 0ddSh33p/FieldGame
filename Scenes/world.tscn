npc_group = "GrassPerson"
my_dialogue = Array[String](["All those rocky losers are as $dense% as the stones they stand on. ", "We ought to end this once and for all.", "There has been enough bloodshed recently from us grass folk.", "I've made my mind up.", "I am done just thinking of these rocks as $foolish%.s", "The time for action has come.", "It is time to end this.", "For the child."])
